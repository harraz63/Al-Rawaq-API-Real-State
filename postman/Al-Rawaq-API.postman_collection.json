        {
          "name": "Update Property Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"available\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/admin/properties/{{propertyId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "properties",
                "{{propertyId}}",
                "status"
              ]
            },
            "description": "Updates a property's status. Requires admin role.\n\nAllowed values: `available` | `pending` | `rejected`\n\nA property must have `status: \"available\"` before it can be added to featured properties via `PUT /admin/featured-properties`."
          },
          "response": []
        },
        {
          "name": "Set Featured Properties",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.properties && json.properties.length > 0) {",
                  "        pm.collectionVariables.set('propertyId', json.properties[0]._id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyIds\": [\n    \"{{propertyId}}\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/admin/featured-properties",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "featured-properties"
              ]
            },
            "description": "Sets up to 8 featured properties ordered by display priority (1 = most prominent).\n\nIMPORTANT: Only properties with `status: \"available\"` can be featured. Use `PATCH /admin/properties/:id/status` to approve a property before featuring it.\n\nReplaces any previous featured selection entirely."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
